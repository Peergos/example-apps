{
    "displayName": "Web Office",
    "description": "Office suite - github.com/Peergos/example-apps/#WebOffice",
    "version": "0.7.1",
    "author": "peergos",
    "launchable": true,
	"folderAction": false,
	"appIcon": "icon.png",
	"fileExtensions": ["docx","odt","xlsx","ods","odp","pptx","odg","ott","ots","otp","otg"],
	"newFileExtensions": [
		{"extension": "docx", "name": "Microsoft Word"},
		{"extension": "odt", "name": "ODF Text Document"},
		{"extension": "ott", "name": "ODF Text Template"},
		{"extension": "xlsx", "name": "Microsoft Excel"},
		{"extension": "ods", "name": "ODF Spreadsheet"},
		{"extension": "ots", "name": "ODF Spreadsheet Template"},
		{"extension": "pptx", "name": "Microsoft PowerPoint"},
		{"extension": "odp", "name": "ODF Presentation"},
		{"extension": "otp", "name": "ODF Presentation Template"},
		{"extension": "odg", "name": "ODF Drawing"},
		{"extension": "otg", "name": "ODF Drawing Template"}
	],
    "permissions": ["EDIT_CHOSEN_FILE", "CSP_UNSAFE_EVAL"]
}